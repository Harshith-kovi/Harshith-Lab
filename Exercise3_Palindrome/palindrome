package Practicals;
import java.util.Scanner;

public class Palindrome {
    static long factorialIterative(int n) {
        if(n<0) throw new IllegalArgumentException("Negative numbers are not allowed"); 
        long result = 1;
        for(int i = 2; i <= n; i++) result *= i;
            return result;
        }
    static long factorialRecursive(int n) {
        if(n<0) throw new IllegalArgumentException("Negative not allowed");
        return(n<=1) ? 1: n * factorialRecursive(n-1);
    }

    static boolean isPalindrome(String s) {
        String clean = s.replaceAll("A-Za-z0-9", "").toLowerCase();
        int i=0, j = clean.length() - 1;
        while (i<j) {
            if(clean.charAt(i) != clean.charAt(j)) return false;
            i++;
            j--;
        }
        return true;
}
public static void main(String[] args) {
        try (Scanner sc = new Scanner(System.in)) {
            System.out.print("Enter a string to test palindrome: ");
            String input = sc.nextLine();
            System.out.println("Is Palindrome ?"+ isPalindrome(input));
            
            System.out.print("Enter a number to check factorial of: ");
            int n = sc.nextInt();
            System.out.println("Iterative factorial:"+ factorialIterative(n));
            System.out.println("Recursivefactorial:"+ factorialRecursive(n));
        }
    }
}
